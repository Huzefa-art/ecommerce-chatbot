# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: openai | groq
LLM_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# ── Data Source ─────────────────────────────────────────────────────────────
# Options: sqlite | airtable
DATA_SOURCE=sqlite
SQLITE_DB_PATH=./ecommerce.db

# ── Airtable ─────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PRODUCTS_TABLE=Products
AIRTABLE_ORDERS_TABLE=Orders
AIRTABLE_FAQ_TABLE=FAQs

# ── App ───────────────────────────────────────────────────────────────────────
DEMO_MODE=false
CHROMA_PERSIST_DIR=./chroma_db
MAX_PRODUCTS_PER_QUERY=6
MAX_RAG_RESULTS=4
CACHE_TTL_SECONDS=300
