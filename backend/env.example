# ── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Airtable ─────────────────────────────────────────────────────────────────
# Leave empty to use DEMO_MODE with bundled data
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PRODUCTS_TABLE=Products
AIRTABLE_ORDERS_TABLE=Orders
AIRTABLE_FAQ_TABLE=FAQs

# ── App ───────────────────────────────────────────────────────────────────────
# DEMO_MODE=true uses bundled product data (no Airtable required)
DEMO_MODE=true
CHROMA_PERSIST_DIR=./chroma_db
MAX_PRODUCTS_PER_QUERY=6
MAX_RAG_RESULTS=4
CACHE_TTL_SECONDS=300
